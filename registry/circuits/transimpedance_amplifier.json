{
  "id": "transimpedance_amplifier",
  "name": "Transimpedance Amplifier",
  "description": "Op-amp based transimpedance amplifier (TIA) that converts photodiode current to voltage. Feedback R_f sets gain; C_f controls stability. Used in optical receivers and precision sensors.",
  "spice_template": "circuits/transimpedance_amplifier/transimpedance_amplifier.template",
  "simulation_type": "ac",
  "parameters": [
    {
      "name": "R_f",
      "label": "Feedback Resistor",
      "unit": "Ω",
      "min": 1000.0,
      "max": 1000000.0,
      "default": 100000.0,
      "scale": "log",
      "description": "Transimpedance gain setting resistor"
    },
    {
      "name": "C_f",
      "label": "Feedback Capacitor",
      "unit": "F",
      "min": 1e-13,
      "max": 1e-10,
      "default": 1e-12,
      "scale": "log",
      "description": "Compensation capacitor for stability"
    }
  ],
  "metrics": [
    {
      "name": "Transimpedance_dBOhm",
      "label": "Transimpedance Gain",
      "unit": "dBΩ",
      "optimize": "maximize",
      "target_default": 100.0,
      "valid_range": {"min": 60.0, "max": 120.0},
      "description": "20*log10(Vout/Iin) in dBΩ, equals 20*log10(R_f)"
    },
    {
      "name": "Bandwidth_Hz",
      "label": "-3dB Bandwidth",
      "unit": "Hz",
      "optimize": "maximize",
      "target_default": 10000000.0,
      "valid_range": {"min": 100000.0, "max": 100000000.0},
      "description": "Closed-loop -3dB bandwidth"
    },
    {
      "name": "Phase_Margin_deg",
      "label": "Phase Margin",
      "unit": "°",
      "optimize": "maximize",
      "target_default": 60.0,
      "valid_range": {"min": 30.0, "max": 85.0},
      "description": "Stability margin - distance from 180° phase shift at unity loop gain"
    }
  ],
  "model": {
    "surrogate_path": "trained_models/transimpedance_amplifier/circuit_model.pkl",
    "scaler_path": "trained_models/transimpedance_amplifier/feature_scaler.pkl",
    "trained_on": null,
    "samples": null,
    "r2_scores": {},
    "model_type": "random_forest",
    "log_metrics": []
  },
  "supply": {
    "comment": "Op-amp assumed to have dual supply or single supply with virtual ground"
  },
  "fixed_components": {
    "Cpd": {"value": 10e-12, "unit": "F", "description": "Photodiode junction capacitance"},
    "op_amp_GBW": {"value": 100e6, "unit": "Hz", "description": "Op-amp gain-bandwidth product"},
    "op_amp_A0": {"value": 100000, "unit": "V/V", "description": "Op-amp DC open-loop gain"}
  },
  "operating_point": {
    "equations": {
      "transimpedance": "R_f",
      "transimpedance_dBOhm": "20 * log10(R_f)",
      "feedback_zero": "1 / (2 * pi * R_f * C_f)",
      "input_pole": "1 / (2 * pi * R_f * Cpd)",
      "noise_gain_peak_freq": "sqrt(GBW / (2 * pi * R_f * Cpd))",
      "closed_loop_BW_approx": "sqrt(GBW / (2 * pi * R_f * Cpd))"
    },
    "stability_requirements": {
      "phase_margin_min": 45.0,
      "comment": "For stability, feedback zero should be placed to compensate input pole"
    }
  },
  "design_constraints": [
    {
      "name": "compensation_ratio",
      "expression": "C_f >= sqrt(Cpd / (2 * pi * R_f * GBW))",
      "description": "Minimum C_f for 45° phase margin (Q=0.707 critically damped)"
    },
    {
      "name": "bandwidth_limit",
      "expression": "BW < GBW / 10",
      "description": "Closed-loop bandwidth should be well below op-amp GBW"
    },
    {
      "name": "gain_bandwidth_tradeoff",
      "expression": "R_f * BW < GBW",
      "description": "Fundamental gain-bandwidth tradeoff limit"
    }
  ],
  "validity_checks": {
    "instability": {
      "condition": "Phase_Margin_deg < 30.0",
      "description": "Phase margin below 30° indicates potential instability or ringing"
    },
    "overcompensated": {
      "condition": "Phase_Margin_deg > 85.0",
      "description": "Excessive phase margin suggests over-compensation, wasting bandwidth"
    },
    "bandwidth_too_high": {
      "condition": "Bandwidth_Hz > 500000000.0",
      "description": "Bandwidth exceeding 500MHz (half of GBW) is physically unrealistic"
    }
  }
}
